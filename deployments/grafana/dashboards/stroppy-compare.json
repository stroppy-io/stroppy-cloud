{
  "id": null,
  "uid": "stroppy-compare",
  "title": "Stroppy Compare",
  "tags": [
    "stroppy",
    "compare"
  ],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "style": "dark",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "run_a",
        "label": "Run A",
        "type": "custom",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "options": []
      },
      {
        "name": "run_b",
        "label": "Run B",
        "type": "custom",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "title": "Database Performance",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "TPS Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{stroppy_run_id=\"$run_a\"}[5m]) + rate(pg_stat_database_xact_rollback{stroppy_run_id=\"$run_a\"}[5m]))",
          "legendFormat": "Run A",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{stroppy_run_id=\"$run_b\"}[5m]) + rate(pg_stat_database_xact_rollback{stroppy_run_id=\"$run_b\"}[5m]))",
          "legendFormat": "Run B",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "title": "Active Connections Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{stroppy_run_id=\"$run_a\"})",
          "legendFormat": "Run A",
          "refId": "A"
        },
        {
          "expr": "sum(pg_stat_activity_count{stroppy_run_id=\"$run_b\"})",
          "legendFormat": "Run B",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "title": "System",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "collapsed": false
    },
    {
      "title": "CPU Usage Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "avg(100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",stroppy_run_id=\"$run_a\"}[5m])) * 100))",
          "legendFormat": "Run A CPU",
          "refId": "A"
        },
        {
          "expr": "avg(100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",stroppy_run_id=\"$run_b\"}[5m])) * 100))",
          "legendFormat": "Run B CPU",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Memory Usage Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "expr": "avg(100 * (1 - node_memory_MemAvailable_bytes{stroppy_run_id=\"$run_a\"} / node_memory_MemTotal_bytes{stroppy_run_id=\"$run_a\"}))",
          "legendFormat": "Run A Memory",
          "refId": "A"
        },
        {
          "expr": "avg(100 * (1 - node_memory_MemAvailable_bytes{stroppy_run_id=\"$run_b\"} / node_memory_MemTotal_bytes{stroppy_run_id=\"$run_b\"}))",
          "legendFormat": "Run B Memory",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Disk IO",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "collapsed": false
    },
    {
      "title": "Disk Read Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "targets": [
        {
          "expr": "sum(rate(node_disk_read_bytes_total{stroppy_run_id=\"$run_a\"}[5m]))",
          "legendFormat": "Run A Read",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_disk_read_bytes_total{stroppy_run_id=\"$run_b\"}[5m]))",
          "legendFormat": "Run B Read",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Disk Write Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "targets": [
        {
          "expr": "sum(rate(node_disk_written_bytes_total{stroppy_run_id=\"$run_a\"}[5m]))",
          "legendFormat": "Run A Write",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_disk_written_bytes_total{stroppy_run_id=\"$run_b\"}[5m]))",
          "legendFormat": "Run B Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "title": "Stroppy",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "collapsed": false
    },
    {
      "title": "Iterations/s Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 52
      },
      "targets": [
        {
          "expr": "sum(rate(stroppy_iterations_total{stroppy_run_id=\"$run_a\"}[30s]))",
          "legendFormat": "Run A",
          "refId": "A"
        },
        {
          "expr": "sum(rate(stroppy_iterations_total{stroppy_run_id=\"$run_b\"}[30s]))",
          "legendFormat": "Run B",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "title": "Query Duration p99 Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 60
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(stroppy_run_query_duration_milliseconds_bucket{stroppy_run_id=\"$run_a\"}[30s])))",
          "legendFormat": "Run A p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(stroppy_run_query_duration_milliseconds_bucket{stroppy_run_id=\"$run_b\"}[30s])))",
          "legendFormat": "Run B p99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "title": "VUs Comparison",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 68
      },
      "targets": [
        {
          "expr": "sum(stroppy_vus{stroppy_run_id=\"$run_a\"})",
          "legendFormat": "Run A",
          "refId": "A"
        },
        {
          "expr": "sum(stroppy_vus{stroppy_run_id=\"$run_b\"})",
          "legendFormat": "Run B",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    }
  ]
}