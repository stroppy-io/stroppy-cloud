{
  "uid": "stroppy-system",
  "title": "System — Node Exporter",
  "tags": ["stroppy", "system"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "style": "dark",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "run_id",
        "label": "Run ID",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(up{stroppy_run_id!=\"\"}, stroppy_run_id)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(up{stroppy_run_id=\"$run_id\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "CPU Usage %",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Memory Usage %",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{stroppy_run_id=\"$run_id\",instance=~\"$instance\"} / node_memory_MemTotal_bytes{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Disk IO Read",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} {{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Disk IO Write",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(node_disk_written_bytes_total{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} {{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Network RX",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{stroppy_run_id=\"$run_id\",instance=~\"$instance\",device!=\"lo\"}[1m])",
          "legendFormat": "{{instance}} {{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Network TX",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(node_network_transmit_bytes_total{stroppy_run_id=\"$run_id\",instance=~\"$instance\",device!=\"lo\"}[1m])",
          "legendFormat": "{{instance}} {{device}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Load Average",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "node_load1{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}} 1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}} 5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}} 15m",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Filesystem Usage %",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{stroppy_run_id=\"$run_id\",instance=~\"$instance\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{stroppy_run_id=\"$run_id\",instance=~\"$instance\",fstype!~\"tmpfs|overlay\"} * 100)",
          "legendFormat": "{{instance}} {{mountpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    }
  ]
}
