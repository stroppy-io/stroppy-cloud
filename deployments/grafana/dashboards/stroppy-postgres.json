{
  "uid": "stroppy-postgres",
  "title": "PostgreSQL — Database Metrics",
  "tags": ["stroppy", "postgres"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "style": "dark",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "run_id",
        "label": "Run ID",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(pg_stat_database_xact_commit{stroppy_run_id!=\"\"}, stroppy_run_id)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": "VictoriaMetrics",
        "query": "label_values(pg_up{stroppy_run_id=\"$run_id\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "TPS (Commits + Rollbacks)",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(pg_stat_database_xact_commit{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} commits/s",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(pg_stat_database_xact_rollback{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} rollbacks/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Active Connections",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{stroppy_run_id=\"$run_id\",instance=~\"$instance\",state=\"active\"}",
          "legendFormat": "{{instance}} {{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Rows Fetched/s",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(pg_stat_database_tup_fetched{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Rows Inserted / Updated / Deleted",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(pg_stat_database_tup_inserted{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} inserted",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(pg_stat_database_tup_updated{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} updated",
          "refId": "B"
        },
        {
          "expr": "sum by (instance) (rate(pg_stat_database_tup_deleted{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} deleted",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Database Size",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "pg_database_size_bytes{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}} {{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Locks by Mode",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "pg_locks_count{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}} {{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (instance) (pg_stat_database_blks_hit{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}) / (sum by (instance) (pg_stat_database_blks_hit{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}) + sum by (instance) (pg_stat_database_blks_read{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Replication Lag",
      "type": "timeseries",
      "datasource": "VictoriaMetrics",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "pg_replication_lag{stroppy_run_id=\"$run_id\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    }
  ]
}
