# Production environment — copy to .env.production and fill in real values.
# Start: docker compose --profile prod --env-file .env.production up -d

# Bind all services to localhost (Caddy handles external traffic)
BIND_ADDR=127.0.0.1

# PostgreSQL
POSTGRES_PASSWORD=<change-me>

# JWT signing secret (32+ chars)
JWT_SECRET=<change-me>

# VictoriaMetrics auth token
MONITORING_TOKEN=<change-me>

# Stroppy admin password
STROPPY_ADMIN_PASSWORD=<change-me>

# Grafana
GF_ADMIN_PASSWORD=<change-me>
GF_ANON_ENABLED=false

# Grafana: URL as seen by the browser (proxied through Caddy)
GRAFANA_URL=https://cloud.stroppy.io/grafana
GF_ROOT_URL=https://cloud.stroppy.io/grafana/
GF_SERVE_SUB_PATH=true

# Yandex Cloud (optional)
YC_TOKEN=
YC_CLOUD_ID=
YC_FOLDER_ID=
